# SusMeter AI - backend environment
# Same knobs the frontend used to own (see frontend/.env.example).
PREMIUM_PRICE=29
IMPROVEMENT_PERCENT=70

# AI flavor layer. off = fully hardcoded deterministic verdicts (demo-safe).
# live = Claude rewrites quotes/recommendations, falls back to hardcoded on any error.
AI_MODE=off
# Required only when AI_MODE=live:
# ANTHROPIC_API_KEY=sk-ant-...

# CORS: comma-separated list of allowed origins (in addition to localhost and *.vercel.app)
# ALLOWED_ORIGINS=https://your-frontend.vercel.app
