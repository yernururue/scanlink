{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "susmeter-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev", "--", "--webpack"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "susmeter-backend",
      "runtimeExecutable": ".venv/bin/python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--app-dir", "backend", "--port", "1488"],
      "port": 1488
    }
  ]
}
