# SusMeter AI — frontend environment (copy to .env and adjust)
NEXT_PUBLIC_PREMIUM_PRICE=29
NEXT_PUBLIC_IMPROVEMENT_PERCENT=70

# Phase 2: the standalone FastAPI backend (backend/) owns the API contract.
# Comment this out to fall back to the Next.js route handlers in src/app/api/*.
# Local dev: http://localhost:1488
# Production: set to your backend Vercel URL (e.g. https://susmeter-backend.vercel.app)
# Comment out entirely to use Next.js built-in API routes as fallback.
NEXT_PUBLIC_API_BASE_URL=http://localhost:1488
